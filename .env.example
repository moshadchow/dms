# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/dms_db
DB_ECHO=false

# ── JWT ───────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── File Storage ──────────────────────────────
STORAGE_ROOT=storage/uploads
MAX_FILE_SIZE_MB=50

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Application ───────────────────────────────
DEBUG=true
APP_NAME=Document Management System
APP_VERSION=1.0.0
